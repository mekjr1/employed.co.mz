{
  "root": true,
  "extends": ["plugin:security/recommended"],
  "plugins": ["security"],
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2020": true,
    "mocha": true
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none", "varsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-redeclare": "off",
    "semi": ["warn", "always"],
    "no-console": ["warn", { "allow": ["warn", "error"] }]
  },
  "ignorePatterns": [
    "node_modules/",
    "public/"
  ]
}
