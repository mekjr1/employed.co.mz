{
  "root": true,
  "extends": ["plugin:security/recommended"],
  "plugins": ["security"],
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2020": true,
    "meteor": true,
    "mocha": true,
    "jquery": true
  },
  "globals": {
    "Meteor": "readonly",
    "Mongo": "readonly",
    "MongoInternals": "readonly",
    "WebApp": "readonly",
    "BrowserPolicy": "readonly",
    "Accounts": "readonly",
    "Template": "readonly",
    "Blaze": "readonly",
    "Tracker": "readonly",
    "ReactiveVar": "readonly",
    "SubsManager": "readonly",
    "Session": "readonly",
    "Router": "readonly",
    "Iron": "readonly",
    "Email": "readonly",
    "HTTP": "readonly",
    "DDPRateLimiter": "readonly",
    "SyncedCron": "readonly",
    "Migrations": "readonly",
    "Restivus": "readonly",
    "RssFeed": "readonly",
    "sitemaps": "readonly",
    "Roles": "readonly",
    "AutoForm": "readonly",
    "settleSimulatedIntent": "readonly",
    "SimpleSchema": "readonly",
    "Modal": "readonly",
    "Stripe": "readonly",
    "Avatar": "readonly",
    "getSlug": "readonly",
    "moment": "readonly",
    "_": "readonly",
    "$": "readonly",
    "sanitizeHtml": "readonly",
    "check": "readonly",
    "Match": "readonly",
    "Package": "readonly",
    "Npm": "readonly",
    "grecaptcha": "readonly",
    "UPLOADCARE_MANUAL_START": "writable",
    "Jobs": "writable",
    "PaymentIntents": "writable",
    "Payments": "writable",
    "Profiles": "writable",
    "Users": "writable",
    "JobReports": "writable",
    "UserProfileSchema": "writable",
    "UserSchema": "writable",
    "USER_PROTECTED_FIELDS": "writable",
    "STATUSES": "readonly",
    "PROFILE_STATUSES": "readonly",
    "MARKETS": "readonly",
    "DEFAULT_MARKET_KEY": "readonly",
    "COUNTRIES": "readonly",
    "JOB_TYPES": "readonly",
    "JOB_REPORT_REASONS": "readonly",
    "JOB_REPORT_RESOLUTIONS": "readonly",
    "ADMIN_GRANTABLE_ROLES": "readonly",
    "FEATURED_JOB_PRICING": "readonly",
    "FEATURED_JOB_AMOUNT_CENTS": "readonly",
    "FEATURED_JOB_CURRENCY": "readonly",
    "FEATURED_JOB_PRICE_LABEL": "readonly",
    "AD_ALLOWED_TEMPLATES": "readonly",
    "AD_DENSITY_PER_PAGE": "readonly",
    "APP_NAME": "readonly",
    "APP_TAGLINE": "readonly",
    "FeaturedCheckout": "writable",
    "FROM_EMAIL": "readonly",
    "SETTINGS_PLACEHOLDERS": "readonly",
    "marketFromHostname": "readonly",
    "marketKeyFromHostname": "readonly",
    "marketFromConnection": "readonly",
    "marketFromKey": "readonly",
    "marketFromCountry": "readonly",
    "currentMarket": "readonly",
    "currentMarketKey": "readonly",
    "absoluteUrlForHost": "readonly",
    "daysUntilExpiration": "readonly",
    "getUserName": "readonly",
    "getUserEmail": "readonly",
    "cleanHtml": "readonly",
    "htmlEscapeForEmail": "readonly",
    "hashIdentifier": "readonly",
    "assertEmailVerifiedIfSignedIn": "readonly",
    "notifyAdminOfStatusChange": "readonly",
    "notifyPosterOfStatusChange": "readonly",
    "notifyPosterOfSubmission": "readonly",
    "brandedEmail": "readonly",
    "verifyRecaptchaV3": "readonly",
    "log": "readonly",
    "ensureDevAccount": "readonly",
    "SUMMERNOTE_OPTIONS": "readonly",
    "SUMMERNOTE_OPTIONS_MOBILE": "readonly",
    "SUMMERNOTE_OPTIONS_FOR_VIEWPORT": "readonly",
    "JOB_STATUS_TABS": "readonly",
    "Translations": "readonly",
    "LOCALES": "readonly",
    "LOCALE_LABELS": "readonly",
    "currentLocale": "readonly",
    "currentLocaleTag": "readonly",
    "resolveBucket": "readonly",
    "setLocale": "readonly",
    "t": "readonly",
    "applySeo": "readonly",
    "AppDialog": "readonly",
    "UI": "readonly",
    "subs": "readonly",
    "SEO": "readonly",
    "getRecaptchaToken": "readonly",
    "loadRecaptcha": "readonly",
    "refreshTotalCount": "writable",
    "Random": "readonly",
    "ReactiveDict": "readonly",
    "JOBS_PAGE_SIZES": "readonly",
    "JOBS_DEFAULT_PAGE_SIZE": "readonly",
    "JOBS_AD_EVERY": "readonly",
    "JobsTotal": "writable",
    "JobsTotalFingerprint": "writable",
    "JobsFilter": "writable",
    "applyJsonLd": "readonly",
    "clearJsonLd": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none", "varsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-redeclare": "off",
    "semi": ["warn", "always"],
    "no-console": ["warn", { "allow": ["warn", "error"] }]
  },
  "ignorePatterns": [
    "node_modules/",
    ".meteor/",
    "packages/",
    "public/",
    "settings-*.json"
  ]
}
