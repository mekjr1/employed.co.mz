# Environment variables — employed.co.mz
#
# Copy to `.env` and fill in real values. Never commit `.env`.
# Meteor also reads `settings-docker.json` via --settings; env vars
# listed here take precedence where the code checks both.

# --- Core (set by docker-compose for dev) ---
MONGO_URL=mongodb://mongo:27017/employed
ROOT_URL=http://localhost:3000
MAIL_URL=smtp://mailhog:1025

# --- Sentry (S-03) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Stripe (S-07 payments) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (S-01 — Resend, future) ---
# RESEND_API_KEY=
# EMAIL_FROM=no-reply@employed.xibodev.com

# --- UAT domain (S-07 CI/CD) ---
# APP_BASE_URL=https://employed.xibodev.com
