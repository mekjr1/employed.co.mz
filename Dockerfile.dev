# Meteor 2.7.1 ships a Node 14 toolchain and its Fibers runtime bundle does
# not boot under Node 18. Keep the dev image aligned with Galaxy / prod until
# the app upgrades to Meteor 2.16+ or Meteor 3.
FROM node:14-bullseye

# A9.12 — METEOR_ALLOW_SUPERUSER was set globally to silence the warning when
# the container runs as root, but it also masks the warning when an operator
# pulls the image and bind-mounts a tree owned by uid 0. The compose service
# sets it explicitly for the dev environment; production images run as a
# non-root user and must not need it.

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    g++ \
    git \
    make \
    python3 \
  && rm -rf /var/lib/apt/lists/*

RUN curl "https://install.meteor.com/?release=2.7.1" | sh

WORKDIR /app

EXPOSE 3000

CMD ["bash", "-lc", "meteor npm install && meteor --settings settings-docker.json --port 0.0.0.0:3000"]
